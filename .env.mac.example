# Mac local development template.
# Copy this to .env or .env.local and fill values from your private records.
# Never commit real .env files or secrets.

POSTGRES_DB=DB_NAME
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5433/DB_NAME

APP_NAME=ibkr-sync
APP_VERSION=0.1.0
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

IBKR_FLEX_URL=https://ndcdyn.interactivebrokers.com/AccountManagement/FlexWebService
IBKR_FLEX_VERSION=3
IBKR_REQUEST_TIMEOUT_SECONDS=30
IBKR_STATEMENT_POLL_SECONDS=5
IBKR_STATEMENT_POLL_ATTEMPTS=5
IBKR_TOKEN=
IBKR_QUERY_ID=

APP_TIMEZONE=Asia/Taipei
SYNC_CRON_HOUR=8
SYNC_CRON_MINUTE=30
ENABLE_SYNC_SCHEDULER=false
RAW_XML_DIR=./storage/raw_xml

# Keep market data workers disabled during normal Mac development.
MARKET_DATA_PROVIDER=
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_FEED_MODE=auto
ALPACA_MAX_SYMBOLS=30
YAHOO_FALLBACK_ENABLED=false
YAHOO_FALLBACK_MODE=auto
YAHOO_FALLBACK_INTERVAL_SECONDS=15
YAHOO_FALLBACK_MAX_SYMBOLS=30
YAHOO_FALLBACK_WRITE_CANDLES=false
YAHOO_FALLBACK_TIMEOUT_SECONDS=10
MARKET_DATA_RETENTION_MINUTES=60
MARKET_DATA_CLEANUP_INTERVAL_SECONDS=300
MARKET_DATA_STATUS_RETENTION_DAYS=7

# Native Next.js dev server can call FastAPI directly.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
